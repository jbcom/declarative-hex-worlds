{
  "name": "@jbcom/medieval-hexagon-gameboard",
  "version": "0.1.0",
  "description": "Deterministic KayKit Medieval Hexagon gameboard runtime with Koota state and FREE GLTF assets",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./actors": {
      "types": "./dist/actors.d.ts",
      "import": "./dist/actors.js"
    },
    "./gameboard": {
      "types": "./dist/gameboard.d.ts",
      "import": "./dist/gameboard.js"
    },
    "./catalog": {
      "types": "./dist/catalog.d.ts",
      "import": "./dist/catalog.js"
    },
    "./coordinates": {
      "types": "./dist/coordinates.d.ts",
      "import": "./dist/coordinates.js"
    },
    "./compatibility": {
      "types": "./dist/compatibility.d.ts",
      "import": "./dist/compatibility.js"
    },
    "./commands": {
      "types": "./dist/commands.d.ts",
      "import": "./dist/commands.js"
    },
    "./koota": {
      "types": "./dist/koota.d.ts",
      "import": "./dist/koota.js"
    },
    "./layout": {
      "types": "./dist/layout.d.ts",
      "import": "./dist/layout.js"
    },
    "./navigation": {
      "types": "./dist/navigation.d.ts",
      "import": "./dist/navigation.js"
    },
    "./occupancy": {
      "types": "./dist/occupancy.d.ts",
      "import": "./dist/occupancy.js"
    },
    "./patrol": {
      "types": "./dist/patrol.d.ts",
      "import": "./dist/patrol.js"
    },
    "./pieces": {
      "types": "./dist/pieces.d.ts",
      "import": "./dist/pieces.js"
    },
    "./movement": {
      "types": "./dist/movement.d.ts",
      "import": "./dist/movement.js"
    },
    "./quests": {
      "types": "./dist/quests.d.ts",
      "import": "./dist/quests.js"
    },
    "./projection": {
      "types": "./dist/projection.d.ts",
      "import": "./dist/projection.js"
    },
    "./recipe": {
      "types": "./dist/recipe.d.ts",
      "import": "./dist/recipe.js"
    },
    "./grid": {
      "types": "./dist/grid.d.ts",
      "import": "./dist/grid.js"
    },
    "./interop": {
      "types": "./dist/interop.d.ts",
      "import": "./dist/interop.js"
    },
    "./ingest": {
      "types": "./dist/ingest.d.ts",
      "import": "./dist/ingest.js"
    },
    "./registry": {
      "types": "./dist/registry.d.ts",
      "import": "./dist/registry.js"
    },
    "./rules": {
      "types": "./dist/rules.d.ts",
      "import": "./dist/rules.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./rule-types": {
      "types": "./dist/rule-types.d.ts",
      "import": "./dist/rule-types.js"
    },
    "./scenario": {
      "types": "./dist/scenario.d.ts",
      "import": "./dist/scenario.js"
    },
    "./simulation": {
      "types": "./dist/simulation.d.ts",
      "import": "./dist/simulation.js"
    },
    "./selectors": {
      "types": "./dist/selectors.d.ts",
      "import": "./dist/selectors.js"
    },
    "./systems": {
      "types": "./dist/systems.d.ts",
      "import": "./dist/systems.js"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "import": "./dist/validation.js"
    },
    "./world-rules": {
      "types": "./dist/world-rules.d.ts",
      "import": "./dist/world-rules.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./three": {
      "types": "./dist/three.d.ts",
      "import": "./dist/three.js"
    },
    "./manifest/free": {
      "types": "./dist/manifest/free.d.ts",
      "import": "./dist/manifest/free.js"
    },
    "./manifest/schema": {
      "types": "./dist/manifest/schema.d.ts",
      "import": "./dist/manifest/schema.js"
    },
    "./assets/free/*": "./assets/free/*",
    "./examples/simple-rpg-usage": {
      "types": "./dist/examples/simple-rpg-usage.d.ts",
      "import": "./dist/examples/simple-rpg-usage.js"
    },
    "./examples/*.json": "./examples/*.json"
  },
  "bin": {
    "medieval-hexagon-gameboard": "./dist/cli.js"
  },
  "files": [
    "assets/free",
    "dist",
    "examples/*.json",
    "README.md",
    "NOTICE.md"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "clean": "rimraf dist",
    "lint": "biome lint src tests examples *.ts *.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:browser:free": "pnpm exec vitest run tests/browser/free-visual.test.ts --config vitest.browser.free.config.ts -t \"captures a contact sheet\" && pnpm exec vitest run tests/browser/free-visual.test.ts --config vitest.browser.free.config.ts -t \"extracted guide pages\" && pnpm exec vitest run tests/browser/free-visual.test.ts --config vitest.browser.free.config.ts -t \"road guide permutations\" && pnpm exec vitest run tests/browser/free-visual.test.ts --config vitest.browser.free.config.ts -t \"river guide permutations\" && pnpm exec vitest run tests/browser/free-visual.test.ts --config vitest.browser.free.config.ts -t \"curvy river\" && pnpm exec vitest run tests/browser/free-visual.test.ts --config vitest.browser.free.config.ts -t \"coast guide permutations\" && pnpm exec vitest run tests/browser/free-visual.test.ts --config vitest.browser.free.config.ts -t \"guide page terrain\" && pnpm exec vitest run tests/browser/free-visual.test.ts --config vitest.browser.free.config.ts -t \"composed gameboard\" && pnpm exec vitest run tests/browser/free-visual.test.ts --config vitest.browser.free.config.ts -t \"seeded random\" && pnpm exec vitest run tests/browser/free-visual.test.ts --config vitest.browser.free.config.ts -t \"seeded hexagon\" && pnpm exec vitest run tests/browser/free-visual.test.ts --config vitest.browser.free.config.ts -t \"generated-piece\" && pnpm exec vitest run tests/browser/simple-rpg-visual.test.ts --config vitest.browser.free.config.ts && pnpm exec vitest run tests/browser/react-bindings.test.ts --config vitest.browser.free.config.ts && pnpm run test:screenshots:free",
    "test:browser:extra": "MEDIEVAL_HEXAGON_ENABLE_EXTRA=1 vitest run --config vitest.browser.extra.config.ts && pnpm run test:screenshots:extra",
    "test:e2e:local-assets": "MEDIEVAL_HEXAGON_ENABLE_LOCAL_ASSETS=1 vitest run --config vitest.browser.local-assets.config.ts && pnpm run test:screenshots:local-assets",
    "test:visual": "pnpm run test:browser:free && pnpm run test:browser:extra && pnpm run test:e2e:local-assets",
    "test:screenshots:free": "tsx tests/scripts/assert-screenshots.ts tests/browser/__screenshots__/free-catalog.png tests/browser/__screenshots__/free-guide-source-pages.png tests/browser/__screenshots__/free-guide-scenarios-by-extracted-page.png tests/browser/__screenshots__/free-guide-roads-all-labels-rotations.png tests/browser/__screenshots__/free-guide-rivers-all-labels-rotations-water-waterless.png tests/browser/__screenshots__/free-guide-river-curvy-crossings-all-modes.png tests/browser/__screenshots__/free-guide-coasts-all-labels-rotations-water-waterless.png tests/browser/__screenshots__/free-guide-page-nature-stacks-buildings-props.png tests/browser/__screenshots__/free-gameboard-recipe.png tests/browser/__screenshots__/free-seeded-gameboard.png tests/browser/__screenshots__/free-seeded-hex-gameboard.png tests/browser/__screenshots__/free-generated-piece-recipe.png tests/browser/__screenshots__/simple-rpg-fixed-completed.png tests/browser/__screenshots__/simple-rpg-seeded-completed.png tests/browser/__screenshots__/simple-rpg-packaged-scenario.png tests/browser/__screenshots__/simple-rpg-simulation-report.png",
    "test:screenshots:extra": "tsx tests/scripts/assert-screenshots.ts --minHeight 200 tests/browser/__screenshots__/extra-local-all-tiles-guide-and-transitions.png tests/browser/__screenshots__/extra-local-all-buildings-factions-neutral-harbors.png tests/browser/__screenshots__/extra-local-all-decoration-nature-props.png tests/browser/__screenshots__/extra-local-all-units-full-accent-neutral-siege.png tests/browser/__screenshots__/extra-seasonal-textures.png tests/browser/__screenshots__/extra-harbor-gameboard.png",
    "test:screenshots:local-assets": "tsx tests/scripts/assert-screenshots.ts tests/browser/__screenshots__/simple-rpg-local-third-party-assets.png",
    "prepublishOnly": "pnpm -w test:ci"
  },
  "keywords": [
    "kaykit",
    "hexagon",
    "hex-grid",
    "medieval",
    "gltf",
    "threejs",
    "game-assets",
    "gameboard",
    "koota",
    "ecs",
    "react"
  ],
  "author": "Jon Bogaty <jon@jonbogaty.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jbcom/medieval-hexagon-gameboard.git",
    "directory": "packages/medieval-hexagon-gameboard"
  },
  "homepage": "https://github.com/jbcom/medieval-hexagon-gameboard/tree/main/packages/medieval-hexagon-gameboard#readme",
  "bugs": {
    "url": "https://github.com/jbcom/medieval-hexagon-gameboard/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "honeycomb-grid": "^4.1.5",
    "koota": "^0.6.6",
    "seedrandom": "^3.0.5"
  },
  "peerDependencies": {
    "@types/react": ">=18.0.0 <20",
    "react": ">=18.0.0 <20",
    "three": ">=0.180.0 <1"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "three": {
      "optional": true
    }
  }
}
