{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@jbcom/medieval-hexagon-gameboard": ["src/index.ts"],
      "@jbcom/medieval-hexagon-gameboard/*": ["src/*"]
    },
    "types": ["node", "vitest/globals"]
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "examples/**/*.ts", "*.ts"],
  "exclude": ["dist", "assets/free"]
}
