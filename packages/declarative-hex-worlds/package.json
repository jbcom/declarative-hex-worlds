  "bin": {
    "declarative-hex-worlds": "./dist/cli.js"
  },
  "files": [
    "assets/free/manifest.json",
    "docs/showcases",
    "dist",
    "!dist/**/*.map",
    "!dist/**/*.d.ts.map",
    "examples/*.json",
    "LICENSE",
    "README.md",
    "NOTICE.md"
  ],
  "scripts": {
    "assets:guide": "tsx scripts/extract-kaykit-guide.ts",
    "assets:free": "tsx scripts/generate-package-assets.ts --edition free --source references/KayKit_Medieval_Hexagon_Pack_1.0_FREE",
    "showcases:promote": "tsx scripts/promote-showcases.ts",
    "build": "tsup --config tsup.config.ts",
    "clean": "rimraf dist coverage",
    "lint": "biome lint docs scripts src tests examples *.json *.md *.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:browser:free": "pnpm exec vitest run tests/browser/free-visual.test.ts --config vitest.browser.free.config.ts -t \"captures a contact sheet\" && pnpm exec vitest run tests/browser/free-visual.test.ts --config vitest.browser.free.config.ts -t \"extracted guide pages\" && pnpm exec vitest run tests/browser/free-visual.test.ts --config vitest.browser.free.config.ts -t \"road guide permutations\" && pnpm exec vitest run tests/browser/free-visual.test.ts --config vitest.browser.free.config.ts -t \"river guide permutations\" && pnpm exec vitest run tests/browser/free-visual.test.ts --config vitest.browser.free.config.ts -t \"curvy river\" && pnpm exec vitest run tests/browser/free-visual.test.ts --config vitest.browser.free.config.ts -t \"coast guide permutations\" && pnpm exec vitest run tests/browser/free-visual.test.ts --config vitest.browser.free.config.ts -t \"guide page terrain\" && pnpm exec vitest run tests/browser/free-visual.test.ts --config vitest.browser.free.config.ts -t \"composed gameboard\" && pnpm exec vitest run tests/browser/free-visual.test.ts --config vitest.browser.free.config.ts -t \"blueprint builder\" && pnpm exec vitest run tests/browser/free-visual.test.ts --config vitest.browser.free.config.ts -t \"seeded random\" && pnpm exec vitest run tests/browser/free-visual.test.ts --config vitest.browser.free.config.ts -t \"seeded hexagon\" && pnpm exec vitest run tests/browser/free-visual.test.ts --config vitest.browser.free.config.ts -t \"generated-piece\" && pnpm exec vitest run tests/browser/feature-gallery.spec.ts --config vitest.browser.free.config.ts && pnpm exec vitest run tests/browser/react-bindings.test.ts --config vitest.browser.free.config.ts && pnpm run test:screenshots:free",
    "test:browser:extra": "HEX_WORLDS_ENABLE_EXTRA=1 vitest run --config vitest.browser.extra.config.ts && pnpm run test:screenshots:extra",
    "test:e2e:local-assets": "pnpm --filter @declarative-hex-worlds/examples test:browser:local-assets",
    "test:simple-rpg": "vitest run tests/integration/simple-rpg/simple-rpg.test.ts",
    "test:bootstrap-cli:e2e:github": "HEX_WORLDS_E2E_GITHUB=1 vitest run --config vitest.bootstrap-cli-e2e.config.ts tests/e2e/bootstrap-cli-github.test.ts",
    "test:bootstrap-cli:e2e:local": "HEX_WORLDS_LOCAL_REFERENCES=1 vitest run --config vitest.bootstrap-cli-e2e.config.ts tests/e2e/bootstrap-cli-local-extra.test.ts",
    "test:visual": "pnpm run test:browser:free && pnpm run test:browser:extra && pnpm run test:e2e:local-assets",
    "test:screenshots:free": "tsx tests/scripts/assert-screenshots.ts tests/browser/__screenshots__/free-catalog.png tests/browser/__screenshots__/free-guide-assets-by-public-role.png tests/browser/__screenshots__/free-guide-source-pages.png tests/browser/__screenshots__/free-guide-scenarios-by-extracted-page.png tests/browser/__screenshots__/free-guide-roads-all-labels-rotations.png tests/browser/__screenshots__/free-guide-rivers-all-labels-rotations-water-waterless.png tests/browser/__screenshots__/free-guide-river-curvy-crossings-all-modes.png tests/browser/__screenshots__/free-guide-coasts-all-labels-rotations-water-waterless.png tests/browser/__screenshots__/free-guide-page-nature-stacks-buildings-props.png tests/browser/__screenshots__/free-gameboard-recipe.png tests/browser/__screenshots__/free-blueprint-builder-showcase.png tests/browser/__screenshots__/free-seeded-gameboard.png tests/browser/__screenshots__/free-seeded-hex-gameboard.png tests/browser/__screenshots__/free-generated-piece-recipe.png tests/browser/__screenshots__/feature-gallery/fixed-harbor.png",
    "test:screenshots:extra": "tsx tests/scripts/assert-screenshots.ts --minHeight 200 tests/browser/__screenshots__/extra-local-all-tiles-guide-and-transitions.png tests/browser/__screenshots__/extra-local-all-buildings-factions-neutral-harbors.png tests/browser/__screenshots__/extra-local-all-decoration-nature-props.png tests/browser/__screenshots__/extra-local-all-units-full-accent-neutral-siege.png tests/browser/__screenshots__/extra-guide-assets-by-public-role.png tests/browser/__screenshots__/extra-guide-scenarios-pages-02-15.png tests/browser/__screenshots__/extra-guide-scenarios-pages-16-18.png tests/browser/__screenshots__/extra-seasonal-textures.png tests/browser/__screenshots__/extra-harbor-gameboard.png tests/browser/__screenshots__/extra-blueprint-biome-transition-showcase.png",
    "expectations": "vitest run --config vitest.config.ts tests/unit/examples.test.ts tests/unit/game-flow-branch-coverage.test.ts",
    "verify": "pnpm lint && pnpm typecheck && pnpm audit --prod --audit-level=high && pnpm build && pnpm expectations && pnpm test && pnpm test:coverage:enforce",
    "bench": "vitest bench --run",
    "bench:warm-start": "vitest bench tests/perf/warm-start.bench.ts --run",
    "bench:cli-cold-start": "pnpm build && vitest bench tests/perf/cli-cold-start.bench.ts --run",
    "bench:simulation": "vitest bench tests/perf/simulation.bench.ts --run",
    "test:coverage": "HEX_WORLDS_COVERAGE=1 vitest run --coverage",
    "test:coverage:enforce": "HEX_WORLDS_COVERAGE=1 HEX_WORLDS_COVERAGE_ENFORCE=1 vitest run --coverage",
    "test:coverage:browser:free": "HEX_WORLDS_COVERAGE=1 vitest run --config vitest.browser.free.config.ts --coverage",
    "test:coverage:browser:extra": "HEX_WORLDS_ENABLE_EXTRA=1 HEX_WORLDS_COVERAGE=1 vitest run --config vitest.browser.extra.config.ts --coverage",
    "coverage:merge": "tsx scripts/merge-coverage.ts",
    "coverage:merge:enforce": "HEX_WORLDS_COVERAGE_ENFORCE=1 tsx scripts/merge-coverage.ts",
    "coverage:all": "rimraf coverage && pnpm test:coverage && pnpm test:coverage:browser:free && pnpm coverage:merge",
    "coverage:all:enforce": "rimraf coverage && pnpm test:coverage && pnpm test:coverage:browser:free && pnpm coverage:merge:enforce",
    "cli": "node dist/cli.js",
    "coverage:ledger": "pnpm build && node dist/cli.js coverage --checksPassed --generatedAt 2026-05-24T00:00:00.000Z --outJson docs/release-readiness.json --outMarkdown docs/guides/release-readiness.md",
    "docs": "typedoc --options typedoc.json",
    "//docs-site": "docs-site/ is a sibling Astro Starlight project — NOT a pnpm workspace member. We dropped workspaces in R1 (see PRD Epic R), so docs-site keeps its own package.json + lockfile and these scripts delegate via `cd docs-site && pnpm ...`. This keeps the library's tarball devDependencies focused on the runtime; the docs site's Astro/Starlight chain lives in its own dependency tree.",
    "docs-site:install": "cd docs-site && pnpm install",
    "docs-site:dev": "cd docs-site && pnpm dev",
    "docs-site:build": "tsx scripts/generate-cli-reference.ts && cd docs-site && pnpm build",
    "docs-site:preview": "cd docs-site && pnpm preview",
    "prepublishOnly": "pnpm verify"
  },
