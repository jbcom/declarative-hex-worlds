{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "src/**",
      "tests/**",
      "examples/**",
      "scripts/**/*.ts",
      "docs/**/*.md",
      "*.json",
      "*.ts",
      "*.yaml",
      "*.yml",
      "*.md"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error",
        "noUnusedFunctionParameters": "warn",
        "noUnsafeFinally": "error",
        "noConstructorReturn": "error",
        "noInnerDeclarations": "error",
        "noUndeclaredVariables": "error"
      },
      "style": {
        "useConst": "error",
        "useAsConstAssertion": "error",
        "noNonNullAssertion": "error",
        "noParameterAssign": "error"
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noGlobalAssign": "error",
        "noPrototypeBuiltins": "error",
        "noShadowRestrictedNames": "error",
        "noUnsafeNegation": "error",
        "noControlCharactersInRegex": "error",
        "noMisleadingCharacterClass": "error"
      },
      "complexity": {
        "noForEach": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "es5",
      "semicolons": "always"
    }
  },
  "json": {
    "formatter": {
      "indentStyle": "space",
      "indentWidth": 2
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
