# Capacitor — android/ is regenerated from capacitor.config.ts by `cap sync`
android
ios

# assets/free/ GLTFs+bins+textures are NOT tracked. Per PRD §Phase RB
# (bootstrap-not-bundle), the published tarball ships only the manifest.json
# metadata; the actual GLTF tree is fetched at install time by the CLI
# `bootstrap` subcommand. Local regeneration via `pnpm assets:free`
# materializes them for testing but they stay out of git.
**/assets/free/**
!**/assets/free/manifest.json
**/models/

# Playwright
playwright-report
test-results
/blob-report
/playwright/.cache

# Vitest browser-mode failure artifacts (Playwright visual baselines under
# tests/e2e and tests/visual ARE committed — these are transient failure shots)
.vitest-attachments
tests/browser/**/__screenshots__/*
!tests/browser/**/__screenshots__/
!tests/browser/**/__screenshots__/feature-gallery/
!tests/browser/**/__screenshots__/feature-gallery/fixed-harbor.png
!tests/browser/**/__screenshots__/free-*.png
!tests/browser/**/__screenshots__/simple-rpg-fixed-completed.png
!tests/browser/**/__screenshots__/simple-rpg-seeded-completed.png
!tests/browser/**/__screenshots__/simple-rpg-packaged-scenario.png
!tests/browser/**/__screenshots__/simple-rpg-simulation-report.png

# macOS
.DS_Store

# agent-state caches (re-derivable; directive.md + decisions.ndjson are tracked)
.agent-state/digest.md
.agent-state/cursor.md
.agent-state/.indexed-sha
.agent-state/.last-stop-sha
.agent-state/.last-compaction
.agent-state/batch.json

# brainstorming companion
.superpowers

# docs-site (Astro Starlight sibling project; PRD F-Site-1)
# Belt-and-braces — docs-site/.gitignore also covers these. The sibling
# install model means docs-site keeps its own node_modules + lockfile.
docs-site/node_modules
docs-site/dist
docs-site/.astro

# Claude Code runtime state (not for git)
.claude/scheduled_tasks.lock
.claude/state/task-batch/

# Local AI-development reference material (findings loops, vendor guide PDFs
# extracted for local reference) — never tracked. Curated output goes elsewhere.
raw-assets/

# Local review scratch archives
.full-review*/
