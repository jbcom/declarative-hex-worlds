{
  "name": "declarative-hex-worlds-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace root for declarative-hex-worlds. Only packages/declarative-hex-worlds is published; simple-rpg and docs-site are private consumers.",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm --filter declarative-hex-worlds build",
    "typecheck": "pnpm --filter declarative-hex-worlds typecheck",
    "lint": "pnpm --filter declarative-hex-worlds lint",
    "test": "pnpm --filter declarative-hex-worlds test",
    "verify": "pnpm --filter declarative-hex-worlds verify",
    "docs-site:dev": "pnpm --filter docs-site dev",
    "docs-site:build": "pnpm --filter docs-site build",
    "bench": "pnpm --filter declarative-hex-worlds bench",
    "coverage:all:enforce": "pnpm --filter declarative-hex-worlds coverage:all:enforce",
    "expectations": "pnpm --filter declarative-hex-worlds expectations",
    "cli": "pnpm --filter declarative-hex-worlds cli"
  },
  "pnpm": {
    "overrides": {
      "yaml": ">=2.8.3",
      "brace-expansion": ">=5.0.6",
      "esbuild@<0.28.1": ">=0.28.1"
    }
  }
}
