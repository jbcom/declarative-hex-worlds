{
  "name": "@jbcom/medieval-hexagon-gameboard-workspace",
  "private": true,
  "description": "Workspace for the @jbcom/medieval-hexagon-gameboard runtime",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9 <10"
  },
  "scripts": {
    "assets:guide": "tsx scripts/extract-kaykit-guide.ts",
    "assets:free": "tsx scripts/generate-package-assets.ts --edition free --source references/KayKit_Medieval_Hexagon_Pack_1.0_FREE --package packages/medieval-hexagon-gameboard",
    "build": "nx run-many -t build",
    "build:package": "nx run @jbcom/medieval-hexagon-gameboard:build",
    "lint": "pnpm lint:workspace && nx run-many -t lint",
    "lint:workspace": "biome lint .github apps docs scripts *.json *.md",
    "typecheck": "pnpm typecheck:workspace && nx run-many -t typecheck",
    "typecheck:workspace": "tsc -p tsconfig.scripts.json",
    "test": "nx run-many -t test",
    "test:browser:free": "nx run @jbcom/medieval-hexagon-gameboard:test:browser:free",
    "test:browser:extra": "nx run @jbcom/medieval-hexagon-gameboard:test:browser:extra",
    "test:e2e:local-assets": "nx run @jbcom/medieval-hexagon-gameboard:test:e2e:local-assets",
    "test:visual": "pnpm test:browser:free && pnpm test:browser:extra && pnpm test:e2e:local-assets",
    "test:screenshots:free": "pnpm --dir packages/medieval-hexagon-gameboard run test:screenshots:free",
    "test:screenshots:extra": "pnpm --dir packages/medieval-hexagon-gameboard run test:screenshots:extra",
    "test:screenshots:local-assets": "pnpm --dir packages/medieval-hexagon-gameboard run test:screenshots:local-assets",
    "test:ci": "pnpm lint && pnpm typecheck && pnpm test:docs-contract && pnpm test:api-docs && pnpm test:assets && pnpm test:workspace && pnpm test:workflows && pnpm build && pnpm test:cli && pnpm test && pnpm test:package && pnpm test:consumer && pnpm pack:dry-run",
    "test:api-docs": "tsx scripts/audit-api-docs.ts",
    "test:assets": "pnpm test:assets:free && pnpm test:reference-assets",
    "test:assets:free": "tsx scripts/audit-free-assets.ts",
    "test:cli": "tsx scripts/smoke-built-cli.ts",
    "test:consumer": "tsx scripts/smoke-packed-consumer.ts",
    "test:docs-contract": "tsx scripts/audit-docs-contract.ts",
    "test:package": "tsx scripts/audit-package.ts",
    "test:workspace": "tsx scripts/audit-workspace.ts",
    "test:workflows": "tsx scripts/audit-workflows.ts",
    "test:reference-assets": "tsx scripts/audit-reference-assets.ts",
    "cli": "node packages/medieval-hexagon-gameboard/dist/cli.js",
    "coverage:ledger": "pnpm build:package && node packages/medieval-hexagon-gameboard/dist/cli.js coverage --checksPassed --generatedAt 2026-05-24T00:00:00.000Z --outJson docs/release-readiness.json --outMarkdown docs/guides/release-readiness.md",
    "docs": "typedoc --options typedoc.json",
    "docs:build": "pnpm run docs && pnpm --dir apps/docs build",
    "pack:dry-run": "cd packages/medieval-hexagon-gameboard && npm pack --dry-run"
  },
  "author": "Jon Bogaty <jon@jonbogaty.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jbcom/medieval-hexagon-gameboard.git"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@nx/js": "^22.7.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/seedrandom": "^3.0.8",
    "@types/three": "^0.184.1",
    "@vitest/browser": "4.1.7",
    "@vitest/browser-playwright": "^4.1.7",
    "nx": "^22.7.2",
    "playwright": "^1.60.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^6.1.3",
    "three": "^0.184.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "vite": "^8.0.14",
    "vitepress": "^2.0.0-alpha.17",
    "vitest": "^4.1.7",
    "vue": "^3.5.34"
  }
}
