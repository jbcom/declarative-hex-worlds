    "@types/node": "^24.10.1",
    "@types/react-dom": "^19.0.0",
    "@types/seedrandom": "^3.0.8",
    "@types/three": "^0.184.1",
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^3.3.1",
    "@vitest/browser": "4.1.7",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "4.1.7",
    "jsdom": "^29.1.1",
    "nyc": "^18.0.0",
    "playwright": "^1.60.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "yazl": "^3.3.1"
  },
  "pnpm": {
    "overrides": {
      "yaml": ">=2.8.3",
      "brace-expansion": ">=5.0.6"
    }
  }
}
