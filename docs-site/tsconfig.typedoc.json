{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "..",
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "baseUrl": "..",
    "paths": {
      "declarative-hex-worlds": ["src/index.ts"],
      "declarative-hex-worlds/*": ["src/*"]
    }
  },
  "include": ["../src/**/*.ts", "../tests/integration/**/*.ts"],
  "exclude": [
    "../dist",
    "../coverage",
    "../node_modules",
    "../assets/free",
    "../src/**/__tests__/**",
    "../tests/**/__tests__/**"
  ]
}
